TaskConfig(description='[Quality Validation] Review requirements quality, identify gaps, and assign severity.\nYOU WILL RECEIVE: - enriched_requirements: {"functional_requirements": [{"id": "FR-001", "description": "Captura autom\\u00e1tica de editais de m\\u00faltiplas fontes p\\u00fablicas e privadas", "source": "from_document", "evidence": "Captar editais automaticamente de m\\u00faltiplas fontes: PNCP, Compras.gov, Portais privados, Portais estaduais/municipais. Capta\\u00e7\\u00e3o di\\u00e1ria incremental. Evitar duplicidade de editais.", "rationale": null, "priority": "high"}, {"id": "FR-002", "description": "Cadastro e gest\\u00e3o do portf\\u00f3lio da empresa com m\\u00faltiplos formatos de entrada", "source": "from_document", "evidence": "Cadastro obrigat\\u00f3rio de portf\\u00f3lio. Aceitar m\\u00faltiplas fontes: PDF, Excel, Texto, Site, Contratos anteriores. Versionamento do portf\\u00f3lio.", "rationale": null, "priority": "high"}, {"id": "FR-003", "description": "An\\u00e1lise completa do edital e anexos com extra\\u00e7\\u00e3o sem\\u00e2ntica", "source": "from_document", "evidence": "Download autom\\u00e1tico de todos os anexos. Descompacta\\u00e7\\u00e3o de ZIP. Leitura de: Edital, Termo de refer\\u00eancia, Modelo de proposta, Minuta de contrato, ETP (quando houver). Extra\\u00e7\\u00e3o sem\\u00e2ntica de: objeto, exig\\u00eancias t\\u00e9cnicas, exig\\u00eancias documentais.", "rationale": null, "priority": "high"}, {"id": "FR-004", "description": "Avalia\\u00e7\\u00e3o de ader\\u00eancia t\\u00e9cnica, documental e log\\u00edstica entre edital e portf\\u00f3lio", "source": "from_document", "evidence": "Avaliar ader\\u00eancia t\\u00e9cnica, documental e log\\u00edstica. Exibir percentual de ader\\u00eancia. Mostrar justificativa item a item. Matching sem\\u00e2ntico entre edital e portf\\u00f3lio. Identifica\\u00e7\\u00e3o de lacunas.", "rationale": null, "priority": "high"}, {"id": "FR-005", "description": "Cadastro de restri\\u00e7\\u00f5es comerciais da empresa e sugest\\u00e3o de alertas de risco", "source": "from_document", "evidence": "Cadastro de restri\\u00e7\\u00f5es da empresa: documentais, regionais, operacionais, financeiras. Sistema n\\u00e3o bloqueia, apenas sinaliza. Registro da decis\\u00e3o humana.", "rationale": null, "priority": "high"}, {"id": "FR-006", "description": "Suporte jur\\u00eddico assistido para identifica\\u00e7\\u00e3o de pontos question\\u00e1veis com base em fontes oficiais", "source": "from_document", "evidence": "Identificar poss\\u00edveis pontos de: impugna\\u00e7\\u00e3o, recurso. Listar fundamentos legais. Pesquisa assistida em: leis, decretos, jurisprud\\u00eancia. Sempre com link, data e fonte oficial.", "rationale": null, "priority": "medium"}, {"id": "FR-007", "description": "Monitoramento autom\\u00e1tico de processos licitat\\u00f3rios participados e n\\u00e3o participados", "source": "from_document", "evidence": "Monitorar processos participados e n\\u00e3o participados. Registrar mudan\\u00e7as de fase. Timeline do processo. Alertas de: Mudan\\u00e7a de fase, Mensagens, Adiamentos.", "rationale": null, "priority": "high"}, {"id": "FR-008", "description": "Detec\\u00e7\\u00e3o e gest\\u00e3o de pend\\u00eancias de editais (ex: aviso sem edital dispon\\u00edvel no PNCP)", "source": "from_document", "evidence": "Detectar aviso publicado sem edital dispon\\u00edvel. Rechecagem autom\\u00e1tica di\\u00e1ria. Notifica\\u00e7\\u00e3o ao usu\\u00e1rio. Upload manual de edital recebido externamente.", "rationale": null, "priority": "high"}, {"id": "FR-009", "description": "Gest\\u00e3o de processos de dispensa de licita\\u00e7\\u00e3o com fluxo diferenciado", "source": "from_document", "evidence": "Identificar modalidade dispensa. Registrar fluxo por e-mail. Controlar prazos. Manter hist\\u00f3rico.", "rationale": null, "priority": "medium"}, {"id": "FR-010", "description": "Interface h\\u00edbrida (chat conversacional + telas tradicionais) para intera\\u00e7\\u00e3o com o sistema", "source": "from_document", "evidence": "Interface tradicional (listas, filtros, dashboards). Interface conversacional orientada a tarefas. Chat com mem\\u00f3ria contextual. Sugest\\u00e3o de pr\\u00f3ximos passos.", "rationale": null, "priority": "medium"}, {"id": "FR-011", "description": "Aprendizado cont\\u00ednuo a partir de corre\\u00e7\\u00f5es e decis\\u00f5es humanas registradas", "source": "from_document", "evidence": "Registro de decis\\u00f5es humanas. Hist\\u00f3rico de corre\\u00e7\\u00f5es. Versionamento de an\\u00e1lises. Aprender com corre\\u00e7\\u00f5es do usu\\u00e1rio. Ajustar pesos e recomenda\\u00e7\\u00f5es.", "rationale": null, "priority": "medium"}, {"id": "FR-012", "description": "Governan\\u00e7a, auditoria e compliance com logs completos e trilhas de auditoria", "source": "from_document", "evidence": "Logs completos de: dados analisados, recomenda\\u00e7\\u00f5es, decis\\u00f5es. Trilhas de auditoria. Controle de acesso.", "rationale": null, "priority": "high"}, {"id": "FR-013", "description": "Conformidade com a LGPD (Lei Geral de Prote\\u00e7\\u00e3o de Dados) no tratamento de dados pessoais", "source": "from_instructions", "evidence": "crie tambem requisitos de lgpd (project goals and context)", "rationale": null, "priority": "high"}, {"id": "FR-014", "description": "Classifica\\u00e7\\u00e3o parametriz\\u00e1vel dos tipos de editais (ex: comodato, venda, aluguel, consumo)", "source": "from_document", "evidence": "Defini\\u00e7\\u00e3o das Telas de Parametriza\\u00e7\\u00f5es da Classifica\\u00e7\\u00e3o dos editais: Ex. Comodatos, Vendas de Equipamentos, Aluguel de Equipamentos com Consumo de Reagentes, Consumo de Reagentes, Compra de Insumos laboratoriais, Compra de Insumos Hospitalares, etc.", "rationale": null, "priority": "high"}, {"id": "FR-015", "description": "Recomenda\\u00e7\\u00e3o de pre\\u00e7os com base em hist\\u00f3ricos de editais ganhos e concorrentes", "source": "from_document", "evidence": "Para os editais com Score de Ader\\u00eancia compat\\u00edvel ou elencados pelo Cliente para gera\\u00e7\\u00e3o de Proposta, a IA indica os pre\\u00e7os m\\u00e9dios praticados pelas empresas que vinham servindo o \\u00f3rg\\u00e3o com base nos editais ganhos anteriormente.", "rationale": null, "priority": "high"}, {"id": "FR-016", "description": "Gera\\u00e7\\u00e3o autom\\u00e1tica de proposta de licita\\u00e7\\u00e3o com anexa\\u00e7\\u00e3o de documentos exigidos", "source": "from_document", "evidence": "Depois de elencada os editais que a empresa quer participar, com base nas an\\u00e1lises previas dos itens anteriores deste roadmap, a IA gera a Proposta do edital em minutos, elaborando todo o texto em linha com as especifica\\u00e7\\u00f5es t\\u00e9cnicas do edital e com base nas especifica\\u00e7\\u00f5es t\\u00e9cnicas do portfolio de produtos.", "rationale": null, "priority": "high"}, {"id": "FR-017", "description": "Alertas de abertura de sess\\u00e3o de preg\\u00e3o para propostas submetidas", "source": "from_document", "evidence": "Para as propostas submetidas, a IA gera alertas na Tela de contagem regressiva para a abertura da sess\\u00e3o do preg\\u00e3o.", "rationale": null, "priority": "high"}, {"id": "FR-018", "description": "Rob\\u00f4 de lances autom\\u00e1ticos para preg\\u00e3o eletr\\u00f4nico com valida\\u00e7\\u00e3o humana", "source": "from_document", "evidence": "Para as propostas submetidas, o sistema permite que a IA proponha em segundos os valores de lances que, antes de serem submetidos, ter\\u00e3o possibilidade de auditados, valida\\u00e7\\u00f5es e edi\\u00e7\\u00f5es r\\u00e1pidas pelo cliente.", "rationale": null, "priority": "high"}, {"id": "FR-019", "description": "Auditoria da proposta do concorrente vencedor e gera\\u00e7\\u00e3o de laudo de contesta\\u00e7\\u00e3o", "source": "from_document", "evidence": "A IA realiza um diagn\\u00f3stico da Proposta e documentos do Concorrente vencedor, vis a vis as especifica\\u00e7\\u00f5es t\\u00e9cnicas solicitadas no edital e gera um SCORE DE recurso que indica a probabilidade de sucesso com base em desvios t\\u00e9cnicos.", "rationale": null, "priority": "high"}, {"id": "FR-020", "description": "Integra\\u00e7\\u00e3o com CRM para alimenta\\u00e7\\u00e3o de leads e gest\\u00e3o de oportunidades", "source": "from_document", "evidence": "Ap\\u00f3s varredura dos editais com ader\\u00eancia e com base nos SCORES DE ADER\\u00caNCIA, a IA pode alimentar os Leads no CRM do Cliente.", "rationale": null, "priority": "medium"}, {"id": "FR-021", "description": "Monitoramento e an\\u00e1lise de licita\\u00e7\\u00f5es perdidas para aprimoramento do portf\\u00f3lio", "source": "from_document", "evidence": "A IA realiza um diagn\\u00f3stico dos principais fatores de perda, listando os motivos. Essas listas servir\\u00e3o de insumo para aprimoramento do portfolio do cliente e para a eleva\\u00e7\\u00e3o do Score de Ader\\u00eancia do Cliente em licita\\u00e7\\u00f5es futuras.", "rationale": null, "priority": "medium"}, {"id": "FR-022", "description": "Capacidade de simula\\u00e7\\u00e3o de cen\\u00e1rios de pre\\u00e7o e margem para recomenda\\u00e7\\u00e3o de pre\\u00e7os", "source": "suggested_by_ai", "evidence": "Baseado em an\\u00e1lise de sistemas an\\u00e1logos (ex: Solf\\u00e1cil) que incluem ferramentas de proje\\u00e7\\u00e3o financeira.", "rationale": "Para apoiar decis\\u00f5es estrat\\u00e9gicas de pricing, \\u00e9 necess\\u00e1rio ir al\\u00e9m da m\\u00e9dia hist\\u00f3rica, permitindo simular diferentes margens, custos e estrat\\u00e9gias de concorr\\u00eancia.", "priority": "medium"}, {"id": "FR-023", "description": "M\\u00f3dulo de colabora\\u00e7\\u00e3o em equipe com @mentions, coment\\u00e1rios e fluxos de aprova\\u00e7\\u00e3o para an\\u00e1lise de editais e propostas", "source": "suggested_by_ai", "evidence": "Identificado como pr\\u00e1tica comum em softwares empresariais complexos e sistemas an\\u00e1logos como TenderEasy.", "rationale": "A decis\\u00e3o sobre participa\\u00e7\\u00e3o em licita\\u00e7\\u00f5es frequentemente envolve m\\u00faltiplos stakeholders (comercial, jur\\u00eddico, t\\u00e9cnico). O sistema deve facilitar a colabora\\u00e7\\u00e3o e rastreabilidade das discuss\\u00f5es.", "priority": "medium"}, {"id": "FR-024", "description": "Relat\\u00f3rios anal\\u00edticos e business intelligence (BI) sobre o mercado de licita\\u00e7\\u00f5es: concorr\\u00eancia mais ativa, \\u00f3rg\\u00e3os que mais compram, sazonalidade, taxa de sucesso", "source": "suggested_by_ai", "evidence": "Funcionalidade presente em sistemas de intelig\\u00eancia de mercado como GovPredict.", "rationale": "Transforma dados operacionais em intelig\\u00eancia estrat\\u00e9gica, ajudando a empresa a direcionar esfor\\u00e7os comerciais e entender tend\\u00eancias do mercado B2G.", "priority": "medium"}, {"id": "FR-025", "description": "Capacidade de configurar e respeitar regras de data residency (resid\\u00eancia de dados), permitindo deploy em infraestrutura nacional ou multi-cloud", "source": "suggested_by_ai", "evidence": "Requisito inferido da LGPD e de demandas comuns do setor p\\u00fablico brasileiro.", "rationale": "Clientes governamentais e a pr\\u00f3pria LGPD podem exigir que dados sens\\u00edveis permane\\u00e7am em territ\\u00f3rio nacional. O sistema deve ser flex\\u00edvel para atender a essas exig\\u00eancias contratuais.", "priority": "high"}], "non_functional_requirements": [{"id": "NFR-001", "description": "Escalabilidade horizontal para suportar aumento no volume de editais e usu\\u00e1rios", "source": "from_document", "evidence": "Escalabilidade horizontal", "rationale": null, "priority": "high"}, {"id": "NFR-002", "description": "Modularidade com IA desacoplada para permitir substitui\\u00e7\\u00e3o ou atualiza\\u00e7\\u00e3o de modelos", "source": "from_document", "evidence": "Modularidade (IA desacoplada)", "rationale": null, "priority": "high"}, {"id": "NFR-003", "description": "Observabilidade completa do sistema para monitoramento de desempenho e depura\\u00e7\\u00e3o", "source": "from_document", "evidence": "Observabilidade", "rationale": null, "priority": "high"}, {"id": "NFR-004", "description": "Custos control\\u00e1veis de IA, com monitoramento e otimiza\\u00e7\\u00e3o de uso", "source": "from_document", "evidence": "Custos control\\u00e1veis de IA", "rationale": null, "priority": "high"}, {"id": "NFR-005", "description": "Fail-safe: sistema deve funcionar em modo degradado sem depend\\u00eancia de IA", "source": "from_document", "evidence": "Fail-safe: sistema funciona sem IA (modo degradado)", "rationale": null, "priority": "high"}, {"id": "NFR-006", "description": "Desempenho: resposta r\\u00e1pida na an\\u00e1lise de editais (ex: dentro de minutos para editais complexos)", "source": "inferred", "evidence": null, "rationale": "Para suportar a tomada de decis\\u00e3o \\u00e1gil no mercado de licita\\u00e7\\u00f5es, a an\\u00e1lise de editais deve ser realizada em tempo h\\u00e1bil.", "priority": "high"}, {"id": "NFR-007", "description": "Seguran\\u00e7a: autentica\\u00e7\\u00e3o, autoriza\\u00e7\\u00e3o e criptografia de dados sens\\u00edveis (portf\\u00f3lio, decis\\u00f5es)", "source": "inferred", "evidence": null, "rationale": "O sistema lida com informa\\u00e7\\u00f5es comerciais sens\\u00edveis e decis\\u00f5es estrat\\u00e9gicas, exigindo prote\\u00e7\\u00e3o contra acessos n\\u00e3o autorizados.", "priority": "high"}, {"id": "NFR-008", "description": "Conformidade com LGPD: tratamento de dados pessoais conforme a Lei 13.709/2018", "source": "from_instructions", "evidence": "crie tambem requisitos de lgpd (project goals and context)", "rationale": null, "priority": "high"}, {"id": "NFR-009", "description": "Alta disponibilidade e disaster recovery para componentes cr\\u00edticos de captura e submiss\\u00e3o de lances, com RTO < 5 minutos e RPO < 1 minuto pr\\u00f3ximo a hor\\u00e1rios de fechamento de preg\\u00e3o", "source": "suggested_by_ai", "evidence": "Inferido da criticidade das funcionalidades FR-017 e FR-018 para o neg\\u00f3cio.", "rationale": "A indisponibilidade durante a fase de lances de um preg\\u00e3o eletr\\u00f4nico pode resultar na perda irrevers\\u00edvel de uma oportunidade comercial valiosa.", "priority": "high"}, {"id": "NFR-010", "description": "Mecanismo de fallback autom\\u00e1tico para componentes de IA: em caso de falha ou degrada\\u00e7\\u00e3o de performance de um modelo, o sistema deve reverter para uma vers\\u00e3o anterior est\\u00e1vel ou para regras pr\\u00e9-definidas (rule-based)", "source": "suggested_by_ai", "evidence": "Melhoria do conceito de fail-safe (NFR-005) com base em melhores pr\\u00e1ticas de MLOps.", "rationale": "Garante a continuidade operacional do servi\\u00e7o de an\\u00e1lise mesmo com problemas em modelos de machine learning, assegurando que o usu\\u00e1rio final n\\u00e3o seja impactado.", "priority": "high"}, {"id": "NFR-011", "description": "Arquitetura compat\\u00edvel com deploy em ambientes h\\u00edbridos ou multi-cloud (ex: AWS, Azure, Google Cloud, on-premises nacional)", "source": "suggested_by_ai", "evidence": "Sugerido por requisitos de data residency da LGPD e demandas do setor p\\u00fablico.", "rationale": "Atende a exig\\u00eancias contratuais de clientes quanto \\u00e0 localiza\\u00e7\\u00e3o f\\u00edsica dos dados (data residency), um ponto cr\\u00edtico em contrata\\u00e7\\u00f5es com o governo.", "priority": "high"}, {"id": "NFR-012", "description": "Autentica\\u00e7\\u00e3o multifator (MFA) obrigat\\u00f3ria para acesso administrativo e para confirma\\u00e7\\u00e3o de a\\u00e7\\u00f5es cr\\u00edticas (ex: submiss\\u00e3o de lances, aprova\\u00e7\\u00e3o de propostas)", "source": "suggested_by_ai", "evidence": "Pr\\u00e1tica padr\\u00e3o de seguran\\u00e7a para sistemas que lidam com dados sens\\u00edveis e transa\\u00e7\\u00f5es financeiras.", "rationale": "Adiciona uma camada cr\\u00edtica de seguran\\u00e7a para prevenir acesso n\\u00e3o autorizado e fraudes, protegendo a integridade das decis\\u00f5es e transa\\u00e7\\u00f5es da empresa.", "priority": "high"}, {"id": "NFR-013", "description": "Prote\\u00e7\\u00e3o contra ataques DDoS e rate limiting configur\\u00e1vel por IP/usu\\u00e1rio para APIs p\\u00fablicas e endpoints de crawling", "source": "suggested_by_ai", "evidence": "Necess\\u00e1rio para garantir disponibilidade e prevenir abuso, especialmente em componentes que interagem com fontes externas.", "rationale": "Protege a infraestrutura de sobrecarga maliciosa ou acidental e evita que crawlers sejam bloqueados por portais fonte devido a excesso de requisi\\u00e7\\u00f5es.", "priority": "high"}, {"id": "NFR-014", "description": "Estrat\\u00e9gia de caching em m\\u00faltiplas camadas (CDN, aplica\\u00e7\\u00e3o, banco) para conte\\u00fado est\\u00e1tico e resultados de an\\u00e1lise frequentemente acessados", "source": "suggested_by_ai", "evidence": "Pr\\u00e1tica essencial para performance de sistemas web escal\\u00e1veis.", "rationale": "Reduz a lat\\u00eancia para o usu\\u00e1rio final, diminui a carga sobre servidores e bancos de dados, e melhora a experi\\u00eancia geral, especialmente para relat\\u00f3rios e dashboards.", "priority": "medium"}, {"id": "NFR-015", "description": "Backup automatizado de todos os dados (bancos de dados, documentos, logs) com reten\\u00e7\\u00e3o m\\u00ednima de 30 dias e capacidade de restore pontual (point-in-time recovery)", "source": "suggested_by_ai", "evidence": "Requisito fundamental de recupera\\u00e7\\u00e3o de desastres (DR) e continuidade de neg\\u00f3cios.", "rationale": "Garante a restaura\\u00e7\\u00e3o do sistema e dos dados em caso de corrup\\u00e7\\u00e3o, exclus\\u00e3o acidental ou desastre, protegendo o ativo de informa\\u00e7\\u00e3o da empresa.", "priority": "high"}, {"id": "NFR-016", "description": "Interface web responsiva, compat\\u00edvel com os principais navegadores e com uso b\\u00e1sico em dispositivos m\\u00f3veis (tablets e smartphones)", "source": "suggested_by_ai", "evidence": "Expectativa padr\\u00e3o do mercado para aplica\\u00e7\\u00f5es empresariais modernas.", "rationale": "Permite que analistas e gestores acompanhem processos e tomem decis\\u00f5es de qualquer lugar, aumentando a agilidade operacional.", "priority": "medium"}, {"id": "NFR-017", "description": "Acessibilidade web conforme as Diretrizes de Acessibilidade para Conte\\u00fado Web (WCAG) 2.1, n\\u00edvel AA", "source": "suggested_by_ai", "evidence": "Requisito legal (Lei Brasileira de Inclus\\u00e3o) e de responsabilidade social, especialmente relevante para intera\\u00e7\\u00e3o com o setor p\\u00fablico.", "rationale": "Garante que o sistema seja utiliz\\u00e1vel por pessoas com defici\\u00eancia, ampliando o alcance e cumprindo obriga\\u00e7\\u00f5es legais.", "priority": "medium"}], "business_rules": [{"id": "BR-001", "description": "IA n\\u00e3o decide sozinha - toda decis\\u00e3o final deve ser humana e registrada", "condition": "Quando o sistema faz uma recomenda\\u00e7\\u00e3o", "action": "Solicitar confirma\\u00e7\\u00e3o e registro da decis\\u00e3o do usu\\u00e1rio"}, {"id": "BR-002", "description": "IA n\\u00e3o inventa informa\\u00e7\\u00f5es - todas as fontes jur\\u00eddicas devem ser verific\\u00e1veis", "condition": "Ao fornecer suporte jur\\u00eddico assistido", "action": "Apresentar apenas informa\\u00e7\\u00f5es com links, datas e fontes oficiais"}, {"id": "BR-003", "description": "Toda recomenda\\u00e7\\u00e3o deve ser explic\\u00e1vel", "condition": "Ao exibir resultados de ader\\u00eancia ou recomenda\\u00e7\\u00f5es", "action": "Fornecer justificativa textual item a item com refer\\u00eancias aos documentos"}, {"id": "BR-004", "description": "O sistema aprende com o uso sem perder rastreabilidade", "condition": "Quando o usu\\u00e1rio corrige uma an\\u00e1lise ou decis\\u00e3o", "action": "Registrar a corre\\u00e7\\u00e3o, manter hist\\u00f3rico e usar para melhorar modelos futuros"}, {"id": "BR-005", "description": "Sistema n\\u00e3o bloqueia participa\\u00e7\\u00e3o em licita\\u00e7\\u00f5es, apenas sinaliza riscos comerciais", "condition": "Ao avaliar restri\\u00e7\\u00f5es comerciais cadastradas", "action": "Exibir alertas de risco, mas permitir que o usu\\u00e1rio prossiga com a decis\\u00e3o"}, {"id": "BR-006", "description": "Em caso de falha ou indisponibilidade de um modelo de IA, o sistema deve automaticamente reverter para uma vers\\u00e3o anterior est\\u00e1vel ou para o modo regra-based (fallback)", "condition": "Quando um componente de IA retorna erro, timeout ou n\\u00edvel de confian\\u00e7a abaixo do limite configurado", "action": "Registrar o evento no log, notificar o administrador, e utilizar o mecanismo de fallback pr\\u00e9-configurado para manter a funcionalidade"}, {"id": "BR-007", "description": "Decis\\u00f5es sobre participa\\u00e7\\u00e3o em licita\\u00e7\\u00f5es de alto valor ou risco requerem aprova\\u00e7\\u00e3o de m\\u00faltiplos n\\u00edveis (ex: analista, gerente, diretoria)", "condition": "Quando o score de ader\\u00eancia est\\u00e1 abaixo de um limiar configurado OU o valor estimado do edital ultrapassa um limite financeiro definido", "action": "Acionar um fluxo de aprova\\u00e7\\u00e3o colaborativo, notificando os aprovadores e impedindo o avan\\u00e7o at\\u00e9 que todas as aprova\\u00e7\\u00f5es sejam registradas"}]} (all requirements including AI suggestions) - business_context: {} - project_name: Análise de Requisitos - Projeto a62c0d72-89f3-4cca-9da2-5a88867cd32e\n═══════════════════════════════════════════════════════════ STEP 1 - QUALITY VALIDATION ═══════════════════════════════════════════════════════════\nReview all requirements (original + suggested) for quality issues:\n(a) AMBIGUOUS LANGUAGE:\n    - Identify vague terms ("fast", "scalable", "user-friendly", "secure")\n    - Flag requirements without specific measurable criteria\n    - Detect undefined terms not in glossary\n\n(b) CONFLICTS/CONTRADICTIONS:\n    - Find requirements that contradict each other\n    - Identify conflicting priorities\n    - Detect inconsistent business rules\n\n(c) TESTABILITY:\n    - Verify each requirement has clear acceptance criteria\n    - Check for measurable metrics (numbers, percentages, time limits)\n    - Ensure requirements are verifiable/testable\n\n(d) COMPLETENESS:\n    - Verify all actors have defined responsibilities\n    - Check all workflows have complete steps\n    - Ensure all entities have attributes defined\n    - Confirm all business rules have conditions and actions\n\n(e) TRACEABILITY:\n    - Verify every requirement has source document citation\n    - Check priority is assigned\n    - Ensure dependencies are mapped\n\n═══════════════════════════════════════════════════════════ STEP 2 - COMPLETENESS EVALUATION ═══════════════════════════════════════════════════════════\n(a) INFORMATION SUFFICIENCY:\n    Assess if extracted information is sufficient for development to begin.\n    Score 0-100 based on completeness of FR, NFR, BR, actors, entities, workflows.\n\n(b) CRITICAL GAPS:\n    Identify missing critical information:\n    - Missing functional areas (e.g., has "Create" but no "Update" or "Delete")\n    - Missing non-functional requirements for key areas (security, performance)\n    - Undefined actors or incomplete actor definitions\n    - Missing error handling or exception scenarios\n\n(c) INFORMATION REQUESTS:\n    Generate specific questions to fill gaps:\n    - What information is needed\n    - Why it\'s critical\n    - What will be blocked without it\n\n(d) COVERAGE BY APPLICATION TYPE:\n    Compare against standards for the application type identified:\n    - Web app: authentication, session management, responsive design, browser support\n    - API: authentication, rate limiting, versioning, error handling, documentation\n    - Mobile: offline mode, push notifications, app permissions, device compatibility\n    - Data platform: data pipeline, ETL, data quality, backup/recovery\n\n═══════════════════════════════════════════════════════════ STEP 3 - ASSIGN SEVERITY TO ISSUES ═══════════════════════════════════════════════════════════\nFor each issue found, assign severity: - CRITICAL: Blocks development, security risk, regulatory violation - HIGH: Significant impact on functionality or quality - MEDIUM: Affects user experience or development efficiency - LOW: Minor issue, cosmetic, or nice-to-have improvement\n', expected_output='JSON object with: {\n  "valid_requirements": [...requirements with quality scores],\n  "issues_found": [\n    {\n      "type": "ambiguous|conflict|testability|completeness|traceability",\n      "severity": "critical|high|medium|low",\n      "description": "detailed description",\n      "affected_requirement_id": "FR-001",\n      "recommended_fix": "suggestion",\n      "example_correction": "example"\n    }\n  ],\n  "quality_scores": {\n    "completeness_score": 0-100,\n    "clarity_score": 0-100,\n    "consistency_score": 0-100,\n    "testability_score": 0-100,\n    "traceability_score": 0-100\n  },\n  "completeness_breakdown": {\n    "functional_requirements": 0-100,\n    "non_functional_requirements": 0-100,\n    "business_rules": 0-100,\n    "actors": 0-100,\n    "entities": 0-100,\n    "workflows": 0-100\n  },\n  "coverage_analysis": {\n    "covered_areas": [...],\n    "missing_areas": [...]\n  },\n  "critical_gaps": [\n    {\n      "gap_type": "missing_functional_area|missing_nfr|undefined_actor",\n      "severity": "critical|high",\n      "description": "what\'s missing",\n      "impact": "impact on development",\n      "justification": "why critical"\n    }\n  ],\n  "information_requests": [\n    {\n      "question": "specific question",\n      "priority": "high|medium|low",\n      "affected_requirements": ["FR-001"],\n      "why_critical": "explanation"\n    }\n  ],\n  "application_type_checklist": {\n    "identified_type": "web|api|mobile|data_platform",\n    "required_items": [...],\n    "covered_items": [...],\n    "missing_items": [...]\n  }\n}\n', tools=[], output_json=None, output_file=None, human_input=False, async_execution=False, context=None, strategy=None, config=None, output_pydantic=None)
